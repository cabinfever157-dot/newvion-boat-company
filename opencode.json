{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "coder",
  "instructions": [
    "C:/Users/info/.gemini/GEMINI.md",
    "./rules.md"
  ],
  "mcp": {
    "neon": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${DATABASE_URL}"
      ],
      "environment": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "memory": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcp-memory-service",
        "--with",
        "onnxruntime",
        "memory",
        "server"
      ],
      "environment": {
        "MCP_MEMORY_STORAGE_BACKEND": "sqlite_vec",
        "MCP_MEMORY_SQLITE_PATH": "C:\\Users\\info\\AppData\\Local\\mcp-memory\\sqlite_vec.db"
      },
      "timeout": 120000
    },
    "memory_project": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcp-memory-service",
        "--with",
        "onnxruntime",
        "memory",
        "server"
      ],
      "environment": {
        "MCP_MEMORY_STORAGE_BACKEND": "sqlite_vec",
        "MCP_MEMORY_SQLITE_PATH": "C:/Projects/Newvion Boat Company/.opencode/memory_project.db",
        "UV_PYTHON_PREFERENCE": "only-managed"
      },
      "timeout": 120000
    },
    "ralph_loop": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "web_search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "environment": {
        "BRAVE_API_KEY": "BSAAl0I1vLIoMsdweJ1ttVp85Stw4aR"
      }
    },
    "stitch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "stitch-mcp@latest"
      ],
      "environment": {
        "STITCH_API_KEY": "AQ.Ab8RN6KsX83qmZlPMHgaMotcr3RSpve_RKVjuE-e9DgNupGY1A"
      }
    },
    "magic_ui": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@magicuidesign/mcp"
      ]
    },
    "browser": {
